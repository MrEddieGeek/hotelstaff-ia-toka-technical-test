# Copia este archivo como .env y ajusta los valores.


# -----------------------------------------------------------
# Infraestructura
# -----------------------------------------------------------
POSTGRES_DB=hotelstaff
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

MONGO_URI=mongodb://mongodb:27017
MONGO_DB=hotelstaff_audit

REDIS_URL=redis://redis:6379/0

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=hotelstaff.events

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=hotelstaff_users

# -----------------------------------------------------------
# Auth / JWT
# -----------------------------------------------------------
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=hotelstaff-auth

# -----------------------------------------------------------
# IA
# -----------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-sustituir
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------
# BFF y Frontend
# -----------------------------------------------------------
BFF_PORT=8080
BFF_CORS_ORIGIN=http://localhost:3000

FRONTEND_PORT=3000
VITE_BFF_URL=http://localhost:8080

# -----------------------------------------------------------
# Modo demo (sembrado automático para presentaciones)
# -----------------------------------------------------------
# Si DEMO_SEED=true, al arrancar:
#   - auth-service crea el admin DEMO_EMAIL/DEMO_PASSWORD si no existe
#   - user-service siembra 4 staff de ejemplo si la tabla está vacía
#     (genera user.created que alimenta audit e ia-agent automáticamente)
DEMO_SEED=true
DEMO_EMAIL=demo@hotelstaff.mx
DEMO_PASSWORD=Demo1234!

# -----------------------------------------------------------
# Observabilidad
# -----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_ENV=local
