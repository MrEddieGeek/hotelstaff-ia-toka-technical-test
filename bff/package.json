{
  "name": "hotelstaff-bff",
  "version": "0.1.0",
  "private": true,
  "description": "BFF (Backend-for-Frontend) que agrega los microservicios de HotelStaffIA",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
